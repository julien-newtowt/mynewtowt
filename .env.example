# NEWTOWT mynewtowt — example environment file
# NE PAS COMMITER .env (gitignored). Renommer en .env et compléter.

# --- App ---
APP_NAME=mynewtowt
APP_VERSION=3.0.0
APP_ENV=development
DEBUG=false
SITE_URL=http://localhost:8000

# --- Security ---
# Must be at least 32 chars and not in the weak_secrets list
SECRET_KEY=change_me_to_a_random_32_chars_or_more_string_here_please

# --- Database ---
DATABASE_URL=postgresql+asyncpg://towt:change_me_local@db:5432/towt
POSTGRES_USER=towt
POSTGRES_PASSWORD=change_me_local
POSTGRES_DB=towt

# --- Session ---
ACCESS_TOKEN_EXPIRE_MINUTES=480       # staff session 8h
CLIENT_SESSION_DAYS=30                # client session 30d
ALGORITHM=HS256

# --- Initial bootstrap ---
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@newtowt.eu
INITIAL_ADMIN_PASSWORD=ChangeMeFirst!2026

# --- External services (optional) ---
PIPEDRIVE_API_TOKEN=
ANTHROPIC_API_KEY=
WINDY_API_KEY=                # Optionnel — météo prévisionnelle (non utilisée en planning)
# Tuiles vectorielles MapLibre (carte /planning/legs/new-from-map, /fleet, tracking).
# Renseigner AU MOINS l'un des deux : MAPTILER_TOKEN est préféré, MAPBOX_TOKEN est
# l'alias historique de repli. Sans token, la carte tombe sur un raster OSM (lent).
# Après modif : `docker compose up -d --force-recreate app` pour recharger l'env.
MAPTILER_TOKEN=
MAPBOX_TOKEN=

# --- Tracking ingest API ---
TRACKING_API_TOKEN=

# --- Tickets escale — escalade SLA ---
TICKETS_SLA_API_TOKEN=           # Token X-API-Token pour POST /api/tickets/escalate-sla (cron Power Automate escalade SLA)

# --- Veille d'actualité (agrégateur NewsData.io) ---
NEWSDATA_API_KEY=                # Clé NewsData.io (https://newsdata.io)
# NEWSDATA_BASE_URL=https://newsdata.io/api/1/latest
VEILLE_API_TOKEN=                # Token X-API-Token pour POST /api/veille/refresh (cron Power Automate)

# --- Email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=NEWTOWT
SMTP_FROM_ADDRESS=no-reply@newtowt.eu
# Boîte de l'équipe commerciale — reçoit les leads (/contact, /devis). Vide → ignoré.
COMMERCIAL_INBOX_EMAIL=

# --- Observability ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_METRICS=true

# --- Backup ---
BACKUP_RETENTION_DAYS=7
BACKUP_S3_BUCKET=
BACKUP_GPG_RECIPIENT=

# --- TLS / Reverse proxy (Caddy) ---
# Domaine pour le certif Let's Encrypt — doit pointer vers l'IP du serveur.
CADDY_DOMAIN=my.newtowt.eu
# Email où Let's Encrypt envoie les notifs d'expiration.
CADDY_EMAIL=communication@towt.eu

# (Legacy, gardés pour compat avec scripts plus anciens)
DOMAIN=my.newtowt.eu
CERTBOT_EMAIL=communication@towt.eu
